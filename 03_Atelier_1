import socketserver

class MyTCPHandler(socketserver.BaseRequestHandler):
    """
    Le gestionnaire de requêtes pour notre serveur.
    """
    def handle(self):
        # self.request est le socket TCP lié au client
        # On lit les données (on suppose ici un message court < 1024 octets)
        self.data = self.request.recv(1024).strip()
        
        print(f"Client ({self.client_address[0]}) a envoyé : {self.data.decode()}")

        # MODIFICATION : On renvoie exactement le message reçu + \n
        # On utilise sendall pour s'assurer que tout le message est bien transmis
        self.request.sendall(self.data + b"\n")

if __name__ == "__main__":
    HOST, PORT = "localhost", 9999

    # On crée le serveur, en le liant à l'hôte et au port choisis
    with socketserver.TCPServer((HOST, PORT), MyTCPHandler) as server:
        print(f"Serveur Echo actif sur {HOST}:{PORT}")
        # On active le serveur ; il tournera jusqu'à un Ctrl-C
        server.serve_forever()
