import socketserver
import threading

class ShutdownTCPHandler(socketserver.BaseRequestHandler):
    """
    Handler qui écoute le mot-clé 'stop' pour éteindre le serveur.
    """
    def handle(self):
        # 1. Réception du message
        self.data = self.request.recv(1024).strip()
        message = self.data.decode(errors="replace")
        
        print(f"Reçu de {self.client_address[0]} : {message}")

        # 2. Vérification du mot-clé
        if message.lower() == "stop":
            self.request.sendall(b"Serveur en cours d'extinction...\n")
            print("Commande 'stop' recue. Fermeture imminente.")
            
            # 3. La clé de l'exercice :
            # On lance shutdown dans un nouveau thread pour ne pas bloquer handle().
            # shutdown() va arrêter la boucle serve_forever().
            threading.Thread(target=self.server.shutdown).start()
            
            # Le handle() se termine ici, le socket client sera fermé par le framework,
            # et le thread auxiliaire pourra alors fermer le serveur.
        else:
            self.request.sendall(b"Message recu. Envoyez 'stop' pour quitter.\n")

if __name__ == "__main__":
    HOST, PORT = "localhost", 9999
    
    # On utilise un TCPServer classique
    with socketserver.TCPServer((HOST, PORT), ShutdownTCPHandler) as server:
        print(f"Serveur pilotable actif sur {PORT}. Envoyez 'stop' pour l'arreter.")
        # Cette méthode bloque jusqu'à ce que .shutdown() soit appelé
        server.serve_forever()
        print("Le serveur s'est arrete proprement.")
