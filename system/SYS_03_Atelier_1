import argparse
import sys

def main():
    # 1. Configuration du parseur d'arguments
    parser = argparse.ArgumentParser(description="Mini-calculatrice en ligne de commande.")
    
    # Premier nombre (positionnel, converti en float)
    parser.add_argument("nb1", type=float, help="Premier nombre")
    
    # Opérateur (positionnel, restreint par choices)
    parser.add_argument("op", choices=["+", "-", "*", "/"], help="Opérateur (+, -, *, /)")
    
    # Deuxième nombre (positionnel, converti en float)
    parser.add_argument("nb2", type=float, help="Deuxième nombre")

    # 2. Analyse des arguments
    args = parser.parse_args()

    # 3. Logique de calcul
    resultat = 0.0
    
    if args.op == "+":
        resultat = args.nb1 + args.nb2
    elif args.op == "-":
        resultat = args.nb1 - args.nb2
    elif args.op == "*":
        resultat = args.nb1 * args.nb2
    elif args.op == "/":
        # Gestion de la division par zéro
        if args.nb2 == 0:
            # Écriture sur stderr (flux d'erreur standard)
            print("Erreur : division par zéro", file=sys.stderr)
            sys.exit(1)
        resultat = args.nb1 / args.nb2

    # 4. Affichage du résultat
    print(f"{args.nb1} {args.op} {args.nb2} = {resultat}")

if __name__ == "__main__":
    main()
